# Telegram
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_user_id_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Bot settings (optional, defaults shown)
MODEL=claude-haiku-4-5-20251001
HISTORY_MESSAGES=30
KNOWLEDGE_DIR=knowledge
PERSONA_FILE=persona.md
DATA_DIR=data

# Stage 2: ElevenLabs (voice)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_cloned_voice_id_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
VOICE_MAX_CHARS=600

# Stage 4: Supabase — оставь пустым для локального SQLite
# Supabase project: ilfaaat-sistema's Project (kcfkhebtlyqgbzaajgiv, eu-central-1 → eu-west)
# URL берём отсюда: https://kcfkhebtlyqgbzaajgiv.supabase.co
# KEY: service_role ключ из Supabase → Project Settings → API → Service Role Key
SUPABASE_URL=
SUPABASE_KEY=

# Stage 3: Video
VIDEO_PROVIDER=veo
VEO_API_KEY=                    # Google AI Studio key (aistudio.google.com) или Vertex AI key
VEO_MODEL=veo-3.1-lite          # точное имя из доки; Veo 2 отключается 30.06.2026
VEO_AUDIO=false                 # звук Veo не нужен — всё равно глушим, кладём ElevenLabs
VEO_RESOLUTION=720p
VIDEO_DAILY_LIMIT_PER_USER=2
VIDEO_TARGET_DURATION=8         # секунд, MVP
# IDENTITY_DIR=identity         # папка с фото-референсами владельца (master.jpg и т.п.)
# VIDEO_CLIPS_DIR=video_clips   # папка с готовыми кружочками-кэшем
